rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function accountEmail() {
      return request.auth.token.email;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/adminEmails/$(accountEmail()));
    }

    match /siteContent/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /assets/{assetId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /registrations/{registrationId} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /contactMessages/{messageId} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow read: if (signedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if false;
    }

    match /adminEmails/{email} {
      allow read: if signedIn() && email == accountEmail();
      allow write: if false;
    }
  }
}
